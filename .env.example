# Copy this to .env and fill in your key. Never commit .env (already in .gitignore).
# Get your key at https://console.anthropic.com/

ANTHROPIC_API_KEY=

# Optional: override model selection.
# Note: ANTHROPIC_MODEL is read by both skill recommendations and resume rewrites.
# Examples:
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-sonnet-4-6
